# ─── DealFlow AI — Environment Variables ─────────────────────────────────────
# Copy to .env.local and fill in values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ─── Supabase Auth ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── AI (Anthropic Claude) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Property Data Providers ─────────────────────────────────────────────────
BATCHDATA_API_KEY=
RENTCAST_API_KEY=

# ─── Maps ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── AI Voice Calling (Bland AI) ─────────────────────────────────────────────
BLAND_API_KEY=
BLAND_WEBHOOK_SECRET=
BLAND_WEBHOOK_URL=
# BLAND_VOICE_ID=           # Optional: custom voice ID
# BLAND_VOICE_SPEED=        # Optional: 0.5-2.0

# ─── SMS (Twilio) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# TWILIO_API_KEY_SID=       # Optional: for browser calling
# TWILIO_API_KEY_SECRET=    # Optional: for browser calling
# TWILIO_TWIML_APP_SID=    # Optional: for browser calling

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=deals@dealflowai.app
SENDGRID_FROM_NAME=DealFlow AI

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=

# ─── Cron Security ───────────────────────────────────────────────────────────
# Secret token for /api/cron/* endpoints (match, digest)
CRON_SECRET=

# ─── Economic Data (optional) ────────────────────────────────────────────────
# FRED_API_KEY=             # Federal Reserve Economic Data

# ─── Voice (optional) ────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=
# ELEVENLABS_DEFAULT_VOICE_ID=

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info            # debug, info, warn, error
