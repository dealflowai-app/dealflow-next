generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WHOLESALER
  BUYER
  BOTH
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String
  firstName String?
  lastName  String?
  phone     String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}
