generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  WHOLESALER
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignMode {
  AI
  MANUAL
}

enum CampaignChannel {
  VOICE
  SMS
  EMAIL
  MULTI_CHANNEL
}

enum CallOutcome {
  QUALIFIED
  NOT_BUYING
  NO_ANSWER
  VOICEMAIL
  WRONG_NUMBER
  DO_NOT_CALL
  CALLBACK_REQUESTED
}

enum BuyerStatus {
  // ── Shared stages ──
  NEW
  CONTACTED
  ACTIVE
  UNDER_CONTRACT
  CLOSED
  DORMANT
  DO_NOT_CALL
  // ── Buyer-specific ──
  QUALIFIED
  HIGH_CONFIDENCE
  RECENTLY_VERIFIED
  // ── Seller-specific ──
  NEGOTIATING
  FINDING_BUYER
  ASSIGNED
  DEAD
}

enum DealStatus {
  DRAFT
  ACTIVE
  UNDER_OFFER
  CLOSED
  CANCELLED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  WITHDRAWN
  EXPIRED
}

enum PropertyType {
  SFR
  MULTI_FAMILY
  LAND
  COMMERCIAL
  MOBILE_HOME
  CONDO
}

enum InvestorStrategy {
  FLIP
  HOLD
  BOTH
  LAND
  COMMERCIAL
}

enum BuyerMotivation {
  HOT           // Ready to buy now, actively looking
  WARM          // Interested, needs the right deal
  COLD          // Not actively looking but open
  NOT_INTERESTED
  DNC           // Do not contact
}

enum BuyerType {
  CASH_BUYER
  FLIPPER
  LANDLORD
  WHOLESALER
  DEVELOPER
  OWNER_OCCUPANT
  HEDGE_FUND
}

enum ContactType {
  BUYER
  SELLER
  BOTH
}

enum FundingSource {
  CASH
  HARD_MONEY
  CONVENTIONAL
  PRIVATE_MONEY
  SELF_DIRECTED_IRA
  LINE_OF_CREDIT
}

enum ContractStatus {
  DRAFT
  SENT
  EXECUTED
  VOIDED
}

enum ListingStatus {
  ACTIVE
  PAUSED
  SOLD
  EXPIRED
}

enum InquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

enum ConditionPreference {
  TURNKEY
  LIGHT_REHAB
  HEAVY_REHAB
  TEARDOWN
  ANY
}

enum CommunicationPreference {
  CALL
  TEXT
  EMAIL
  ANY
}

enum VerificationStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

// ─── CORE MODELS ─────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String
  firstName String?
  lastName  String?
  phone     String?
  role         Role
  platformRole String    @default("user")  // "user" or "admin"
  company      String?
  avatarUrl String?
  settings  Json?          // user preferences & config (inbound routing, etc.)

  // Onboarding
  onboardingCompleted Boolean @default(false)

  // Verification
  emailVerified    Boolean   @default(false)
  phoneVerified    Boolean   @default(false)
  phoneOtp         String?               // hashed OTP for phone verification
  phoneOtpExpires  DateTime?             // OTP expiry time

  // Marketplace reputation & verification
  sellerVerification VerificationStatus @default(NONE)
  sellerVerifiedAt   DateTime?
  reputationScore    Float              @default(0)    // 0-5 star average
  reviewCount        Int                @default(0)    // denormalized count
  completedDeals     Int                @default(0)    // closed marketplace deals

  // Stripe / billing
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  tier                 String    @default("free")  // "free", "starter", "pro", "enterprise"
  tierStatus           String    @default("active") // "active", "past_due", "cancelled", "trialing"
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  savedMarkets         SavedMarket[]
  campaigns            Campaign[]
  deals                Deal[]
  buyers               CashBuyer[]
  scoringConfig        ScoringConfig?
  tags                 Tag[]
  discoveryProperties  DiscoveryProperty[]
  contactReveals       ContactReveal[]
  skipTraceResults     SkipTraceResult[]
  contracts            Contract[]
  marketplaceListings  MarketplaceListing[]
  buyerBoardPosts      BuyerBoardPost[]
  buyerBoardContacts   BuyerBoardContact[]
  analysisCache        AnalysisCache[]
  chatConversations    ChatConversation[]
  complianceLogs       ComplianceLog[]
  abTests              ABTest[]
  campaignTemplates    CampaignTemplate[]
  scheduledCallbacks   ScheduledCallback[]
  voicemailRecordings  VoicemailRecording[]
  inboundCalls         InboundCall[]
  callIntelligence     CallIntelligence[]
  smsConversations     SMSConversation[]
  liveCallSessions     LiveCallSession[]
  usageRecords         Usage[]
  usageAllowances      UsageAllowance[]
  paymentHistory       PaymentHistory[]
  matchAlerts          MatchAlert[]
  notifications        Notification[]
  communityPosts       CommunityPost[]
  postComments         PostComment[]
  postLikes            PostLike[]
  createdGroups        CommunityGroup[] @relation("groupCreator")
  groupMemberships     GroupMember[]
  conversationParticipants ConversationParticipant[]
  sentMessages         DirectMessage[] @relation("sentMessages")
  savedViews           SavedView[]
  activityLogs         ActivityLog[]
  referralCode         String?       @unique
  referralsSent        Referral[]    @relation("ReferralsSent")
  referralsReceived    Referral[]    @relation("ReferralsReceived")
  badges               Badge[]
  ownedTeams           Team[]       @relation("TeamOwner")
  teamMemberships      TeamMember[]

  reviewsReceived    SellerReview[] @relation("ReviewsReceived")
  reviewsGiven       SellerReview[] @relation("ReviewsGiven")

  @@map("profiles")
}

// ─── DISCOVERY CACHE ────────────────────────────────────────────────────────

model DiscoveryProperty {
  id              String   @id @default(uuid())
  userId          String?
  rentcastId      String?  @unique
  addressLine1    String
  city            String
  state           String   // 2-letter code
  zipCode         String?
  county          String?
  latitude        Float?
  longitude       Float?
  propertyType    String?  // Single Family, Multi Family, Condo, Townhouse, Land, Commercial
  bedrooms        Int?
  bathrooms       Float?
  sqft            Int?
  lotSize         Int?
  yearBuilt       Int?
  assessedValue   Int?
  taxAmount       Float?   // annual taxes
  lastSaleDate    DateTime? @db.Date
  lastSalePrice   Int?
  ownerName       String?
  ownerOccupied   Boolean?
  enrichmentLevel Int      @default(0)  // 0=basic (search), 1=core/tax, 2=full detail
  daysOnMarket    Int?     // Populated from listing data enrichment
  listingStatus   String?  // Active, Pending, Sold, Off-Market
  listPrice       Int?     // Current list price
  features        Json?    // raw features from RentCast
  rawResponse     Json?    // Full provider response. For BatchData:
                           // rawResponse.enrichmentLevel, .enrichedAt, .owner, .assessment, .mortgage, .lastSale
  searchCity      String?  // the city that was searched (cache lookup key)
  searchZip       String?  // the zip that was searched (cache lookup key)
  cachedAt        DateTime @default(now())
  expiresAt       DateTime @default(dbgenerated("now() + interval '7 days'"))

  profile Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)
  skipTraceResults  SkipTraceResult[]
  sellerContacts    CashBuyer[]      // Sellers linked to this property
  matchAlerts       MatchAlert[]

  @@unique([addressLine1, city, state], name: "addressCityState")
  @@index([searchCity])
  @@index([searchZip])
  @@index([expiresAt])
  @@index([userId])
  @@map("discovery_properties")
}

// ─── CONTACT REVEALS (skip trace cache) ────────────────────────────────────

model ContactReveal {
  id              String   @id @default(uuid())
  userId          String
  ownerName       String
  propertyAddress String
  city            String
  state           String
  phones          Json?    // [{number, type, score}]
  emails          Json?    // [{address, type, score}]
  mailingAddress  Json?    // {line1, city, state, zip} or null
  confidence      Int?
  provider        String?
  cachedAt        DateTime @default(now())
  expiresAt       DateTime @default(dbgenerated("now() + interval '30 days'"))

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ownerName, propertyAddress])
  @@index([userId])
  @@index([expiresAt])
  @@index([cachedAt])
  @@map("contact_reveals")
}

// ─── SKIP TRACE RESULTS (enriched contact data with DNC/TCPA flags) ────────

model SkipTraceResult {
  id              String   @id @default(uuid())
  propertyId      String?
  userId          String

  // Input
  ownerName       String
  propertyAddress String
  city            String
  state           String
  zipCode         String?

  // Results - phones
  // Each phone: { number, type, verified, doNotCall, litigator, carrier?, lastVerified? }
  phones          Json

  // Results - emails
  // Each email: { address, type?, score, verified }
  emails          Json

  // Results - mailing
  mailingAddress  Json?

  // Metadata
  confidence      Int      @default(0)
  provider        String   @default("batchdata")
  phoneCount      Int      @default(0)
  emailCount      Int      @default(0)
  mobileCount     Int      @default(0)
  hasDoNotCall    Boolean  @default(false)
  hasLitigator   Boolean  @default(false)

  // Cost tracking
  estimatedCost   Float?

  // Cache
  cachedAt        DateTime @default(now())
  expiresAt       DateTime @default(dbgenerated("now() + interval '30 days'"))

  // Relations
  profile         Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  property        DiscoveryProperty? @relation(fields: [propertyId], references: [id])

  @@unique([ownerName, propertyAddress])
  @@index([userId])
  @@index([propertyId])
  @@index([expiresAt])
  @@map("skip_trace_results")
}

// ─── SCORING CONFIGURATION (per-user) ──────────────────────────────────────

model ScoringConfig {
  id        String @id @default(cuid())
  profileId String @unique

  // Custom weights (must sum to 100). Null = use system defaults.
  weightTransaction    Int?   // default 25
  weightRecency        Int?   // default 20
  weightResponsiveness Int?   // default 20
  weightCompleteness   Int?   // default 15
  weightEngagement     Int?   // default 10
  weightClosing        Int?   // default 10

  // Status threshold overrides
  highConfidenceMinScore   Int?   // default 75
  highConfidenceMaxDays    Int?   // default 14
  recentlyVerifiedMaxDays  Int?   // default 14
  dormantMinDays           Int?   // default 90
  dormantMaxScore          Int?   // default 20
  activeMinScore           Int?   // default 40

  // Decay multiplier overrides (0.0 - 1.0)
  decay30to60  Float?  // default 0.9
  decay60to90  Float?  // default 0.75
  decay90to180 Float?  // default 0.5
  decay180plus Float?  // default 0.25

  // Custom tag definitions: [{ tag, label, scoreBonus }]
  customTags Json?  // Array<{ tag: string, label: string, scoreBonus: number }>

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("scoring_configs")
}

// ─── MARKET & BUYER DISCOVERY ────────────────────────────────────────────────

model SavedMarket {
  id            String   @id @default(cuid())
  profileId     String
  label         String   // "Atlanta, GA"
  city          String?
  county        String?
  state         String
  zipCode       String?
  buyerCount    Int      @default(0)
  lastRefreshed DateTime?
  createdAt     DateTime @default(now())

  profile  Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyers   CashBuyer[]

  @@map("saved_markets")
}

model CashBuyer {
  id               String      @id @default(cuid())
  savedMarketId    String?
  profileId        String?
  // Identity
  firstName        String?
  lastName         String?
  entityName       String?     // LLC name if applicable
  entityType       String?     // "individual" | "llc" | "corporation" | "trust"
  // Contact (enriched via Melissa Data)
  phone            String?
  phoneSecondary   String?
  email            String?
  emailSecondary   String?
  address          String?
  city             String?
  state            String?
  zip              String?
  // Purchase history from ATTOM
  cashPurchaseCount  Int       @default(0)
  lastPurchaseDate   DateTime?
  estimatedMinPrice  Int?
  estimatedMaxPrice  Int?
  primaryPropertyType PropertyType?
  // Platform status
  status           BuyerStatus  @default(ACTIVE)
  contactEnriched  Boolean      @default(false)
  enrichedAt       DateTime?
  isOptedOut       Boolean      @default(false)
  optedOutAt       DateTime?
  // CRM data
  notes            String?
  buyerScore       Int          @default(0)  // 0-100, manually set by user
  lastContactedAt  DateTime?
  lastVerifiedAt   DateTime?
  // Wholesaler-specific fields
  motivation          BuyerMotivation?     // How motivated is this buyer right now
  buyerType           BuyerType?           // What kind of buyer (flipper, landlord, etc.)
  fundingSource       FundingSource?       // How they pay (cash, hard money, etc.)
  conditionPreference ConditionPreference? // What condition properties they want
  communicationPref   CommunicationPreference? // How they prefer to be contacted
  preferredZips       String[]             // Specific zip codes they buy in
  portfolioSize       Int?                 // How many properties they currently own
  avgPurchasePrice    Int?                 // Average purchase price from history
  followUpDate        DateTime?            // Next scheduled follow-up
  followUpNote        String?              // What to discuss on follow-up
  source              String?              // Lead source (referral, driving, list, etc.)
  assignedTo          String?              // Team member assigned to this buyer
  // Manual scoring overrides
  scorePinned      Boolean      @default(false)  // if true, auto-rescore skips this buyer
  scoreOverride    Int?         // manually set score (replaces calculated score when set)
  scoreAdjustment  Int          @default(0)       // +/- manual adjustment added to calculated score
  overrideReason   String?      // why the score was manually overridden
  overrideSetAt    DateTime?
  // Custom tags for per-user classification (references ScoringConfig.customTags)
  customTags       String[]     // e.g. ["vip", "repeat_buyer", "slow_closer"]
  // AI Insights
  aiInsight             String?
  aiInsightGeneratedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Contact type (buyer, seller, or both)
  contactType       ContactType  @default(BUYER)

  // Seller-specific fields (null for pure buyers)
  sellerMotivation   String?    // "Pre-foreclosure", "Tax delinquent", "Tired landlord", etc.
  sellerAskingPrice  Int?       // What the seller wants
  sellerPropertyId   String?    // Links to DiscoveryProperty if found via Discovery
  sellerTimeline     String?    // "Urgent (30 days)", "Flexible (90 days)", "No rush"
  sellerNotes        String?    // Free-form notes about the seller situation
  sellerPropertyAddress String? // Readable address for quick display

  // Alert preferences (for buyer-type contacts)
  alertsEnabled      Boolean    @default(false)  // Opt-in to auto-match notifications
  alertFrequency     String     @default("daily") // "realtime", "daily", "weekly"
  lastAlertSentAt    DateTime?  // Track when last alert was sent

  // Buy box preferences (captured from AI calls)
  preferredMarkets    String[]
  preferredTypes      PropertyType[]
  strategy            InvestorStrategy?
  minPrice            Int?
  maxPrice            Int?
  closeSpeedDays      Int?          // how fast they can close
  proofOfFundsVerified Boolean     @default(false)
  maxRehab            Int?         // max rehab budget they'll take on
  minBeds             Int?
  minBaths            Int?
  minSqft             Int?
  yearBuiltMin        Int?         // won't buy older than this

  savedMarket      SavedMarket?   @relation(fields: [savedMarketId], references: [id])
  profile          Profile?       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  discoveryProperty DiscoveryProperty? @relation(fields: [sellerPropertyId], references: [id])
  campaignCalls    CampaignCall[]
  dealMatches      DealMatch[]
  offers           Offer[]
  activityEvents   ActivityEvent[]
  tags             BuyerTag[]
  buyerBoardPosts  BuyerBoardPost[]
  scheduledCallbacks ScheduledCallback[]
  inboundCalls       InboundCall[]
  smsConversations   SMSConversation[]
  matchAlerts        MatchAlert[]

  @@index([savedMarketId])
  @@index([profileId])
  @@index([status])
  @@index([buyerScore])
  @@index([profileId, isOptedOut])
  @@index([profileId, isOptedOut, status])
  @@index([contactType])
  @@map("cash_buyers")
}

// ─── ACTIVITY TIMELINE ──────────────────────────────────────────────────────

model ActivityEvent {
  id        String   @id @default(cuid())
  buyerId   String
  profileId String

  type      String   // "created" | "edited" | "archived" | "imported" | "score_updated" | "status_changed" | "call_completed" | "deal_matched" | "offer_received" | "note_added"
  title     String   // human-readable summary e.g. "Score updated from 42 to 78"
  detail    String?  // optional longer description
  metadata  Json?    // arbitrary payload (changed fields, old/new values, etc.)

  createdAt DateTime @default(now())

  buyer   CashBuyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([profileId, createdAt(sort: Desc)])
  @@index([type])
  @@map("activity_events")
}

// ─── TAGS & SEGMENTATION ────────────────────────────────────────────────────

model Tag {
  id          String   @id @default(cuid())
  profileId   String
  name        String   // "repeat_closer", "hot_lead", "going_cold", etc.
  label       String   // Human-readable: "Repeat Closer", "Hot Lead", "Going Cold"
  color       String   // Hex color for UI pill: "#15803d", "#dc2626", etc.
  type        String   // "auto" (system-generated) or "manual" (user-created)
  description String?  // What this tag means
  createdAt   DateTime @default(now())

  profile Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyers  BuyerTag[]

  @@unique([profileId, name])
  @@index([profileId])
  @@map("tags")
}

model BuyerTag {
  id          String   @id @default(cuid())
  buyerId     String
  tagId       String
  autoApplied Boolean  @default(false) // true if system applied it, false if user applied it
  appliedAt   DateTime @default(now())

  buyer CashBuyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  tag   Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([buyerId, tagId])
  @@index([buyerId])
  @@index([tagId])
  @@map("buyer_tags")
}

// ─── CAMPAIGNS ───────────────────────────────────────────────────────────────

model Campaign {
  id              String         @id @default(cuid())
  profileId       String
  name            String
  market          String         // "Atlanta, GA"
  status          CampaignStatus @default(DRAFT)
  mode            CampaignMode   @default(AI)
  channel         CampaignChannel @default(VOICE)

  // Script config
  scriptTemplate  String         @default("standard_qualification")
  companyName     String?
  agentName       String?
  customScript    String?

  // Calling settings
  maxConcurrentCalls Int         @default(5)
  callingHoursStart  String      @default("09:00")
  callingHoursEnd    String      @default("19:00")
  timezone           String      @default("America/New_York")
  leaveVoicemail     Boolean     @default(true)
  maxRetries         Int         @default(2)
  retryDelayHours    Int         @default(24)

  // Schedule
  scheduledAt     DateTime?
  isRecurring     Boolean        @default(false)

  // Stats (denormalized for performance)
  totalBuyers     Int            @default(0)
  callsCompleted  Int            @default(0)
  qualified       Int            @default(0)
  notBuying       Int            @default(0)
  noAnswer        Int            @default(0)
  totalTalkTime   Int            @default(0) // seconds

  // Cost tracking
  estimatedCost   Float?
  actualCost      Float?

  // Smart scheduling
  useSmartScheduling Boolean @default(true)

  // Voicemail drop
  voicemailRecordingId  String?     // which VM recording to use
  voicemailSequence     Json?       // for smart sequencing: [{ attempt: 1, recordingId: "..." }]

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  profile Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  calls   CampaignCall[]

  @@index([profileId])
  @@index([status])
  @@map("campaigns")
}

model CampaignCall {
  id            String       @id @default(cuid())
  campaignId    String?          // null for manual calls outside campaigns
  buyerId       String
  isManual      Boolean      @default(false)
  // Channel & provider tracking
  channel       String?          // "voice" | "sms" | "email" | "manual_voice"
  messageId     String?          // Twilio SID or SendGrid message ID
  messageSent   Boolean          @default(false)
  messageDelivered Boolean       @default(false)
  messageRead   Boolean          @default(false)
  responseText  String?          // inbound SMS response text
  responseAt    DateTime?        // when they responded
  // Bland AI data
  blandCallId   String?      @unique
  phoneNumber   String
  outcome       CallOutcome?
  durationSecs  Int?
  recordingUrl  String?
  transcript    String?      // raw transcript text
  // AI-extracted structured data
  extractedData Json?        // { stillBuying, preferredTypes, minPrice, maxPrice, strategy, closeSpeed, notes }
  aiSummary     String?
  // Status
  attemptNumber Int          @default(1)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime     @default(now())

  campaign Campaign?  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  buyer    CashBuyer  @relation(fields: [buyerId], references: [id])

  @@index([campaignId])
  @@index([buyerId])
  @@index([outcome])
  @@map("campaign_calls")
}

// ─── A/B TESTING ──────────────────────────────────────────────────────────────

model ABTest {
  id               String    @id @default(cuid())
  profileId        String
  name             String
  status           String    @default("RUNNING") // RUNNING | COMPLETED | CANCELLED
  campaignIdA      String
  campaignIdB      String
  testVariable     String    // "script" | "time" | "channel" | "voicemail"
  variantALabel    String
  variantBLabel    String
  winnerId         String?
  winnerDeclaredAt DateTime?
  confidenceLevel  Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("ab_tests")
}

// ─── CAMPAIGN TEMPLATES ───────────────────────────────────────────────────────

model CampaignTemplate {
  id                 String    @id @default(cuid())
  profileId          String?   // null = system template, set = user-created

  name               String
  description        String?
  category           String    // "qualification" | "deal_alert" | "reactivation" | "follow_up" | "verification" | "custom"
  icon               String?

  // Pre-configured campaign settings
  channel            String    // "VOICE" | "SMS" | "EMAIL" | "MULTI_CHANNEL"
  scriptTemplate     String?
  customScript       String?
  smsTemplateId      String?
  emailSequenceId    String?

  // Default audience filter & settings
  audienceFilter     Json?
  settings           Json?
  multiChannelConfig Json?

  // Usage tracking
  useCount           Int       @default(0)
  lastUsedAt         DateTime?

  isPublic           Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  profile            Profile?  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([category])
  @@index([isPublic])
  @@map("campaign_templates")
}

// ─── SCHEDULED CALLBACKS ──────────────────────────────────────────────────────

model ScheduledCallback {
  id             String    @id @default(cuid())
  profileId      String
  buyerId        String
  campaignId     String?

  scheduledAt    DateTime
  reason         String              // "Buyer requested callback" or "Auto-retry: no answer"
  source         String              // "buyer_request" | "ai_detected" | "manual" | "auto_retry"
  status         String   @default("scheduled")  // "scheduled" | "completed" | "missed" | "cancelled"

  notes          String?             // context from previous call
  previousCallId String?             // reference to the call that generated this callback

  completedAt    DateTime?
  createdAt      DateTime @default(now())

  profile        Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyer          CashBuyer @relation(fields: [buyerId], references: [id])

  @@index([profileId, status, scheduledAt])
  @@index([buyerId])
  @@index([scheduledAt])
  @@map("scheduled_callbacks")
}

model VoicemailRecording {
  id            String   @id @default(cuid())
  profileId     String

  name          String              // "Deal Alert VM" or "Follow Up VM"
  category      String              // "deal_alert" | "follow_up" | "reactivation" | "introduction" | "custom"

  // Audio
  audioUrl      String?             // URL to uploaded recording
  audioData     Bytes?              // raw audio data (stored locally, < 1MB)
  duration      Int?                // seconds
  format        String?             // "mp3" | "wav"

  // TTS alternative
  ttsText       String?             // text to convert to speech
  ttsVoiceId    String?             // ElevenLabs or Bland voice ID
  ttsGenerated  Boolean  @default(false)

  // Usage
  isDefault     Boolean  @default(false)  // default VM for this category
  useCount      Int      @default(0)
  callbackRate  Float?              // percentage of VM drops that resulted in a callback

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, category])
  @@map("voicemail_recordings")
}

model InboundCall {
  id            String   @id @default(cuid())
  profileId     String

  // Call info
  callSid       String   @unique        // Twilio Call SID
  fromPhone     String                   // caller's phone number
  toPhone       String                   // your Twilio number that was called

  // Caller identification
  buyerId       String?                  // matched CashBuyer, null if unknown caller
  buyerName     String?                  // denormalized for quick display
  identified    Boolean  @default(false) // whether we matched to a known buyer

  // Routing
  routedTo      String                   // "ai" | "wholesaler" | "voicemail" | "missed"
  transferredAt DateTime?                // when call was transferred to wholesaler

  // Call data
  status        String   @default("ringing")  // "ringing" | "in-progress" | "completed" | "missed" | "busy"
  duration      Int?
  recordingUrl  String?
  transcript    String?
  aiSummary     String?
  extractedData Json?

  // Context
  relatedCampaignId   String?            // if callback from a specific campaign
  relatedCallId       String?            // the outbound call that triggered this callback
  scheduledCallbackId String?            // if this matches a scheduled callback

  outcome       String?                  // QUALIFIED, NOT_BUYING, etc.
  notes         String?

  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime @default(now())

  profile       Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyer         CashBuyer? @relation(fields: [buyerId], references: [id])

  @@index([profileId, createdAt])
  @@index([fromPhone])
  @@index([buyerId])
  @@index([callSid])
  @@map("inbound_calls")
}

// ─── CONVERSATION INTELLIGENCE ──────────────────────────────────────────────

model CallIntelligence {
  id            String   @id @default(cuid())
  callId        String   @unique         // CampaignCall id
  profileId     String

  // Sentiment
  overallSentiment    String             // "positive" | "neutral" | "negative" | "mixed"
  sentimentScore      Int                // -100 to +100
  sentimentArc        Json?              // array of { segment: number, score: number }

  // Buying signals
  buyingSignals       Json?              // array of { signal, strength, quote }
  buyingSignalCount   Int    @default(0)
  overallBuyingIntent String             // "high" | "medium" | "low" | "none"

  // Objections
  objections          Json?              // array of { objection, category, handled, response }
  objectionCount      Int    @default(0)

  // Competitive mentions
  competitorMentions  Json?              // array of { competitor, context, sentiment }

  // Talk metrics
  aiTalkPercent       Float              // 0-100
  buyerTalkPercent    Float              // 0-100
  idealRatio          Boolean            // true if AI talk < 45%
  longestAiMonologue  Int?               // seconds
  questionCount       Int    @default(0)

  // Engagement
  engagementScore     Int                // 0-100
  engagementSignals   Json?              // array of { signal, type }

  // Highlights
  highlights          Json?              // array of { type, startSegment, endSegment, summary, quote }

  // Script performance
  scriptEffectiveness Int?               // 0-100
  scriptSuggestions   Json?              // array of { suggestion, reason, priority }

  createdAt     DateTime @default(now())

  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([overallSentiment])
  @@index([overallBuyingIntent])
  @@map("call_intelligence")
}

// ─── SMS CONVERSATIONS ─────────────────────────────────────────────────────

model SMSConversation {
  id            String   @id @default(cuid())
  profileId     String
  buyerId       String?              // linked CashBuyer, null if unknown number
  phone         String               // buyer/recipient phone in E.164

  status        String   @default("active")    // "active" | "closed" | "archived"
  mode          String   @default("auto")      // "auto" | "manual" | "hybrid"

  // Last message snapshot for list view
  lastMessageBody   String?
  lastMessageAt     DateTime?
  lastMessageDir    String?          // "inbound" | "outbound"

  unreadCount   Int      @default(0)

  // Campaign link
  campaignId    String?              // originating campaign, if any

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyer         CashBuyer?       @relation(fields: [buyerId], references: [id])
  messages      SMSMessage[]

  @@unique([profileId, phone])
  @@index([profileId, updatedAt(sort: Desc)])
  @@index([profileId, status])
  @@index([buyerId])
  @@map("sms_conversations")
}

model SMSMessage {
  id               String   @id @default(cuid())
  conversationId   String

  direction        String               // "inbound" | "outbound"
  from             String               // E.164 sender
  to               String               // E.164 recipient
  body             String

  sentBy           String?              // "ai" | "wholesaler" | "system" | null (inbound)
  twilioSid        String?  @unique     // Twilio message SID
  status           String   @default("sent")  // "sent" | "delivered" | "failed" | "received"

  // AI classification (inbound only)
  aiClassification String?              // "opt_out" | "interested" | "not_interested" | "question" | "callback_request" | "address_response" | "price_response" | "other"
  aiAutoReplied    Boolean  @default(false)

  createdAt        DateTime @default(now())

  conversation     SMSConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([twilioSid])
  @@map("sms_messages")
}

// ─── LIVE CALL MONITORING ──────────────────────────────────────────────────

model LiveCallSession {
  id            String   @id @default(cuid())
  profileId     String
  callId        String   @unique         // CampaignCall id
  blandCallId   String                   // Bland AI call id

  // Call state
  status        String   @default("active")  // "active" | "monitoring" | "whisper" | "barged_in" | "completed"

  // Monitoring
  monitoringStartedAt DateTime?
  monitoredBy         String?            // profileId of person monitoring

  // Whisper
  whisperMessages     Json?              // array of { message: string, sentAt: string }

  // Barge-in
  bargedInAt          DateTime?
  bargedInBy          String?
  transferSid         String?            // Twilio call SID after transfer

  // Live data
  currentDuration     Int    @default(0)  // seconds, updated periodically
  currentTranscript   String?             // rolling transcript updated in real-time
  lastActivityAt      DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@index([blandCallId])
  @@map("live_call_sessions")
}

model OptOut {
  id          String   @id @default(cuid())
  phone       String   @unique
  email       String?
  reason      String?
  source      String?  // "call_request" | "sms_stop" | "manual" | "webhook" | "import"
  createdAt   DateTime @default(now())

  @@map("opt_outs")
}

// ─── COMPLIANCE AUDIT LOG ──────────────────────────────────────────────────

model ComplianceLog {
  id            String   @id @default(cuid())
  profileId     String
  phone         String
  channel       String   // "voice" | "sms" | "email"
  action        String   // "check" | "opt_out" | "opt_in" | "dnc_import" | "call_blocked" | "call_allowed"
  result        String   // "allowed" | "blocked" | "warning"
  reasons       String[] // block/warning codes
  consentBasis  String?
  metadata      Json?    // full ComplianceCheckResult for auditing

  campaignId    String?
  buyerId       String?

  createdAt     DateTime @default(now())

  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([phone])
  @@index([action])
  @@map("compliance_logs")
}

// ─── DEALS ───────────────────────────────────────────────────────────────────

model Deal {
  id            String       @id @default(cuid())
  profileId     String       // wholesaler who created it

  // Property info
  address       String
  city          String
  state         String
  zip           String
  propertyType  PropertyType @default(SFR)
  beds          Int?
  baths         Float?
  sqft          Int?
  yearBuilt     Int?
  condition     String?      // "distressed" | "fair" | "good" | "excellent"

  // Deal financials
  askingPrice   Int
  assignFee     Int?
  closeByDate   DateTime?
  arv           Int?         // AI-estimated ARV
  repairCost    Int?         // AI-estimated
  confidenceScore Int?       // 0-100

  // AI analysis
  flipProfit    Int?
  rentalCashFlow Int?        // monthly
  analysisData  Json?        // full AI analysis object

  status        DealStatus   @default(DRAFT)
  notes         String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  closedAt      DateTime?

  profile    Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  matches    DealMatch[]
  offers     Offer[]
  contracts  Contract[]
  listings   MarketplaceListing[]

  @@index([profileId])
  @@index([status])
  @@index([profileId, status])
  @@index([profileId, createdAt(sort: Desc)])
  @@map("deals")
}

model DealMatch {
  id          String    @id @default(cuid())
  dealId      String
  buyerId     String
  matchScore  Int       // 0-100
  // Score breakdown
  buyBoxScore    Int    @default(0)
  priceScore     Int    @default(0)
  strategyScore  Int    @default(0)
  timingScore    Int    @default(0)
  closeProbScore Int    @default(0)
  // Outreach
  outreachSent   Boolean  @default(false)
  outreachSentAt DateTime?
  viewed         Boolean  @default(false)
  viewedAt       DateTime?
  createdAt      DateTime @default(now())

  deal  Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  buyer CashBuyer @relation(fields: [buyerId], references: [id])

  @@unique([dealId, buyerId])
  @@index([dealId])
  @@index([buyerId])
  @@index([dealId, matchScore(sort: Desc)])
  @@map("deal_matches")
}

// ─── OFFERS & TRANSACTIONS ───────────────────────────────────────────────────

model Offer {
  id          String      @id @default(cuid())
  dealId      String
  buyerId     String
  amount      Int
  closeDate   DateTime?
  terms       String?
  status      OfferStatus @default(PENDING)
  message     String?
  // Contract
  contractUrl String?
  signedAt    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  deal     Deal       @relation(fields: [dealId], references: [id])
  buyer    CashBuyer  @relation(fields: [buyerId], references: [id])
  contract Contract?

  @@index([dealId])
  @@index([buyerId])
  @@index([dealId, status])
  @@map("offers")
}

// ─── CONTRACTS ──────────────────────────────────────────────────────────────

model Contract {
  id            String         @id @default(cuid())
  profileId     String
  dealId        String
  offerId       String?        @unique
  templateName  String         // e.g. "Texas Assignment of Contract"
  status        ContractStatus @default(DRAFT)
  filledData    Json?          // merged template data (seller, buyer, terms, etc.)
  documentUrl   String?        // generated PDF URL
  currentVersion Int           @default(1)
  sellerSignedAt DateTime?
  buyerSignedAt  DateTime?
  voidedAt       DateTime?
  voidReason     String?

  // ── PandaDoc e-signature fields ──
  pandadocDocumentId  String?  @unique  // PandaDoc document ID
  pandadocStatus      String?  // "document.draft" | "document.sent" | "document.viewed" | "document.completed" | "document.declined" | "document.voided"
  pandadocSentAt      DateTime?
  pandadocCompletedAt DateTime?
  pandadocDeclinedAt  DateTime?
  pandadocDeclineReason String?
  signerStatuses      Json?    // Array of { name, email, role, status, signedAt }

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile  Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  deal     Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  offer    Offer?             @relation(fields: [offerId], references: [id])
  versions ContractVersion[]

  @@index([profileId])
  @@index([dealId])
  @@index([profileId, status])
  @@index([profileId, createdAt(sort: Desc)])
  @@index([pandadocDocumentId])
  @@map("contracts")
}

model ContractVersion {
  id             String   @id @default(cuid())
  contractId     String
  version        Int
  filledData     Json?
  documentUrl    String?
  changeType     String   // "created" | "fields_updated" | "status_changed" | "template_changed" | "restored"
  changeSummary  String?  // human-readable summary
  changedFields  String[] // list of field keys that changed
  previousValues Json?    // snapshot of previous values for changed fields
  changedBy      String   // profileId of who made the change
  createdAt      DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, version])
  @@index([contractId])
  @@map("contract_versions")
}

// ─── MARKETPLACE ────────────────────────────────────────────────────────────

model MarketplaceListing {
  id            String        @id @default(cuid())
  profileId     String
  dealId        String
  status        ListingStatus @default(ACTIVE)

  // Denormalized deal snapshot
  address       String
  city          String
  state         String
  zip           String
  propertyType  PropertyType  @default(SFR)
  askingPrice   Int
  assignFee     Int?
  arv           Int?
  repairCost    Int?
  flipProfit    Int?
  rentalCashFlow Int?
  beds          Int?
  baths         Float?
  sqft          Int?
  yearBuilt     Int?
  condition     String?
  confidenceScore Int?

  // Geocoded coordinates
  latitude      Float?
  longitude     Float?

  // Listing metadata
  headline      String?
  description   String?
  photoUrls     String[]      @default([])
  viewCount     Int           @default(0)
  inquiryCount  Int           @default(0)
  featuredUntil DateTime?
  publishedAt   DateTime?
  soldAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  profile   Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  deal      Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  inquiries MarketplaceInquiry[]
  reviews   SellerReview[]

  @@index([profileId])
  @@index([dealId])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([profileId, status])
  @@map("marketplace_listings")
}

model MarketplaceInquiry {
  id          String        @id @default(cuid())
  listingId   String
  buyerName   String
  buyerEmail  String?
  buyerPhone  String?
  message     String?
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([status])
  @@map("marketplace_inquiries")
}

// ─── BUYER BOARD ────────────────────────────────────────────────────────────

model BuyerBoardPost {
  id             String   @id @default(cuid())
  profileId      String

  // Buyer info (anonymized)
  displayName    String
  buyerType      String?

  // Buy box criteria
  propertyTypes  String[]
  markets        String[]
  strategy       String?
  minPrice       Int?
  maxPrice       Int?
  closeSpeedDays Int?
  proofOfFunds   Boolean  @default(false)

  // Post details
  description    String?
  status         String   @default("ACTIVE")

  // Optional link to actual CRM buyer (private)
  buyerId        String?

  // Engagement
  viewCount      Int      @default(0)
  contactCount   Int      @default(0)

  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile  Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyer    CashBuyer?         @relation(fields: [buyerId], references: [id])
  contacts BuyerBoardContact[]

  @@index([profileId])
  @@index([status])
  @@index([markets])
  @@map("buyer_board_posts")
}

model BuyerBoardContact {
  id        String   @id @default(cuid())
  postId    String
  profileId String
  message   String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())

  post    BuyerBoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile Profile        @relation(fields: [profileId], references: [id])

  @@unique([postId, profileId])
  @@index([postId])
  @@map("buyer_board_contacts")
}

// ─── ANALYSIS CACHE ─────────────────────────────────────────────────────────

model AnalysisCache {
  id          String   @id @default(cuid())
  profileId   String

  // Lookup key
  addressKey  String   // normalized address for matching
  rawAddress  String   // original address string entered

  // Cached result
  result      Json     // full PropertyAnalysis object
  apiCalls    Int      @default(3)

  // Cache control
  cachedAt    DateTime @default(now())
  expiresAt   DateTime // 24 hours after cachedAt

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, addressKey])
  @@index([profileId])
  @@index([expiresAt])
  @@map("analysis_cache")
}

// ─── CHAT CONVERSATIONS ────────────────────────────────────────────────────

model ChatConversation {
  id        String   @id @default(cuid())
  profileId String
  title     String   @default("New conversation")
  messages  Json     // Array of {role, content, timestamp}
  summary   String?  // AI-generated 1-line summary
  pinned    Boolean  @default(false)

  // Sharing
  shareToken String?   @unique // random token for public read-only access
  sharedAt   DateTime?          // when sharing was enabled
  sharedBy   String?            // profileId of who shared it

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([updatedAt])
  @@index([shareToken])
  @@map("chat_conversations")
}

// ─── USAGE TRACKING ──────────────────────────────────────────────────────────

model Usage {
  id              String   @id @default(cuid())
  userId          String
  user            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodEnd       DateTime
  aiCallMinutes   Float    @default(0)
  smsCount        Int      @default(0)
  skipTraces      Int      @default(0)
  dealsAnalyzed   Int      @default(0)
  dealsClosed     Int      @default(0)
  activeDeals     Int      @default(0)
  crmContacts     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, periodStart])
  @@index([userId])
  @@map("usage")
}

// ─── USAGE ALLOWANCES (Sprint 6) ────────────────────────────────────────────

model UsageAllowance {
  id                  String   @id @default(uuid())
  profileId           String

  // Billing period
  periodStart         DateTime
  periodEnd           DateTime

  // Plan allowances (set from Stripe subscription metadata on creation/renewal)
  revealsAllowed      Int      @default(0)
  callMinutesAllowed  Int      @default(0)
  smsAllowed          Int      @default(0)
  analysesAllowed     Int      @default(-1) // -1 = unlimited

  // Current usage
  revealsUsed         Int      @default(0)
  callMinutesUsed     Int      @default(0)
  smsUsed             Int      @default(0)
  analysesUsed        Int      @default(0)

  // Overage tracking (units consumed beyond allowance)
  revealsOverage      Int      @default(0)
  callMinutesOverage  Int      @default(0)
  smsOverage          Int      @default(0)

  // Cost tracking
  estimatedCost       Float    @default(0) // running total of data API costs this period

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, periodStart])
  @@index([profileId])
  @@index([periodEnd])
  @@map("usage_allowances")
}

// ─── PAYMENT HISTORY ─────────────────────────────────────────────────────────

model PaymentHistory {
  id              String    @id @default(cuid())
  userId          String
  user            Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeInvoiceId String?   @unique
  amount          Int       // cents
  currency        String    @default("usd")
  status          String    // "paid", "failed", "refunded"
  description     String?
  invoiceUrl      String?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@map("payment_history")
}

// ─── MATCH ALERTS ──────────────────────────────────────────────────────────

model MatchAlert {
  id          String    @id @default(uuid())
  profileId   String
  buyerId     String
  propertyId  String
  matchScore  Int       @default(0)  // 0-100
  status      String    @default("NEW")  // NEW, SENT, VIEWED, DISMISSED, ACTED_ON

  notifiedAt  DateTime?  // When notification was sent
  viewedAt    DateTime?  // When user viewed it

  createdAt   DateTime  @default(now())

  profile     Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyer       CashBuyer         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  property    DiscoveryProperty @relation(fields: [propertyId], references: [id])

  @@unique([buyerId, propertyId])
  @@index([profileId, status])
  @@index([createdAt])
  @@map("match_alerts")
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  profileId  String
  type       String   // "match_alert", "campaign_complete", "deal_update", "system"
  title      String
  body       String
  data       Json?    // { buyerId, propertyId, campaignId, etc. }
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ─── COMMUNITY FEED ──────────────────────────────────────────────────────────

model CommunityPost {
  id         String   @id @default(uuid())
  profileId  String
  content    String
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile    Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  comments   PostComment[]
  likes      PostLike[]

  @@index([profileId])
  @@index([createdAt])
  @@map("community_posts")
}

model PostComment {
  id         String   @id @default(uuid())
  postId     String
  profileId  String
  content    String
  createdAt  DateTime @default(now())

  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile    Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([profileId])
  @@map("post_comments")
}

model PostLike {
  id         String   @id @default(uuid())
  postId     String
  profileId  String
  createdAt  DateTime @default(now())

  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile    Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([postId, profileId])
  @@index([postId])
  @@map("post_likes")
}

model CommunityGroup {
  id          String   @id @default(uuid())
  name        String
  description String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   Profile        @relation("groupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     GroupMember[]

  @@index([createdAt])
  @@map("community_groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String
  profileId String
  createdAt DateTime @default(now())

  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([groupId, profileId])
  @@index([profileId])
  @@map("group_members")
}

// ─── DIRECT MESSAGES ──────────────────────────────────────────────────────────

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  participants ConversationParticipant[]
  messages     DirectMessage[]
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profileId      String
  profile        Profile      @relation(fields: [profileId], references: [id])
  lastReadAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  @@unique([conversationId, profileId])
  @@map("conversation_participants")
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         Profile      @relation("sentMessages", fields: [senderId], references: [id])
  content        String
  createdAt      DateTime     @default(now())
  @@map("direct_messages")
}

model SavedView {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  page      String   // 'crm', 'deals', or 'discovery'
  name      String
  filters   Json     // stored filter configuration
  isDefault Boolean  @default(false)
  notify    Boolean  @default(false) // notify on new matches
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([profileId, page])
  @@map("saved_views")
}

// ─── ACTIVITY LOG (account-level) ──────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      String   // DEAL_CREATED, BUYER_ADDED, BUYER_IMPORTED, CAMPAIGN_SENT, DEAL_STATUS_CHANGED, CONTRACT_CREATED, POST_CREATED
  title     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
  @@map("activity_logs")
}

// ─── REFERRAL SYSTEM ─────────────────────────────────────────────────────────

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       Profile   @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referredEmail  String
  referredId     String?
  referred       Profile?  @relation("ReferralsReceived", fields: [referredId], references: [id])
  code           String    @unique
  status         String    @default("PENDING") // PENDING, SIGNED_UP, CONVERTED
  reward         String?   // e.g., "7_DAY_EXTENSION", "CREDIT_25"
  rewardClaimed  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  convertedAt    DateTime?

  @@index([referrerId])
  @@index([code])
  @@map("referrals")
}

// ─── GAMIFICATION / BADGES ──────────────────────────────────────────────────

model Badge {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type       String   // FIRST_DEAL, FIVE_DEALS, FIRST_BUYER, TEN_BUYERS, FIFTY_BUYERS, FIRST_CAMPAIGN, DEAL_CLOSED, FIRST_POST, ANALYZER_PRO, EARLY_ADOPTER
  earnedAt   DateTime @default(now())

  @@unique([profileId, type])
  @@index([profileId])
  @@map("badges")
}

// ─── TEAMS & PERMISSIONS ───────────────────────────────────────────────────

model Team {
  id        String       @id @default(cuid())
  name      String
  ownerId   String
  owner     Profile      @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
  createdAt DateTime     @default(now())

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // ADMIN, MANAGER, MEMBER, VIEWER
  joinedAt  DateTime @default(now())

  @@unique([teamId, profileId])
  @@index([teamId])
  @@index([profileId])
  @@map("team_members")
}

// ─── MARKETPLACE REPUTATION ──────────────────────────────────────────────────

model SellerReview {
  id          String  @id @default(cuid())
  sellerId    String                        // the wholesaler being reviewed
  reviewerId  String                        // who wrote the review
  listingId   String?                       // optional link to a specific listing
  rating      Int                           // 1-5 stars
  title       String?
  body        String?
  tags        String[]  @default([])        // e.g. ["responsive", "accurate_description", "fast_close"]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  seller      Profile              @relation("ReviewsReceived", fields: [sellerId], references: [id], onDelete: Cascade)
  reviewer    Profile              @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  listing     MarketplaceListing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@unique([sellerId, reviewerId, listingId])  // one review per reviewer per listing
  @@index([sellerId])
  @@index([reviewerId])
  @@index([listingId])
  @@map("seller_reviews")
}
